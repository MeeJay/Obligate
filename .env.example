# ── Image version (tag Docker Hub, ex: latest, 0.1.0) ──
OBLIGATE_VERSION=latest

# ── Database ──
# If using the built-in postgres container (docker-compose.yml):
DB_PASSWORD=changeme

# If using an external PostgreSQL (docker-compose.external-db.yml):
# DATABASE_URL=postgres://obligate:yourpassword@your-db-host:5432/obligate

# ── Server ──
SESSION_SECRET=change-this-to-a-random-secret

# ── Client origin (for CORS — set to your actual URL) ──
CLIENT_ORIGIN=http://localhost
LISTEN_PORT=3020

# ── Default admin (created on first run) ──
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ── Encryption key for LDAP bind passwords (32 bytes hex) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=
